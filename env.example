# ============================================================
# Variables d'environnement — Comptage de véhicules
# ============================================================
# Ces variables permettent de surcharger la configuration YAML
# sans modifier config.yaml (utile pour les secrets).
# Copiez ce fichier en ".env" et décommentez les lignes souhaitées.
# ============================================================

# Chemin du fichier de configuration YAML (dans le conteneur)
CONFIG_PATH=/app/data/config.yaml

# Fuseau horaire du système
TZ=Europe/Paris

# -- Authentification basique du tableau de bord (optionnel) --
# Laisser vides pour désactiver l'authentification
# DASHBOARD_USERNAME=admin
# DASHBOARD_PASSWORD=changeme

# -- Surcharges de configuration (optionnel) --
# Ces variables remplacent les valeurs du fichier config.yaml

# Dossier des vidéos (chemin dans le conteneur)
# VIDEO_FOLDER=/video

# Chemin de la base de données SQLite
# DB_PATH=/app/data/vehicles.db

# Port du tableau de bord
# DASHBOARD_PORT=8080

# Niveau de log : DEBUG, INFO, WARNING, ERROR
# LOG_LEVEL=INFO

# Rétention des données : supprimer les franchissements de plus de N jours (0 = désactivé)
# DATA_RETENTION_DAYS=365
